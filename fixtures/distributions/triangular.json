{
  "target": "distribution",
  "kind": "distribution",
  "source_test": "HEC.FDA.StatisticsTests/Distributions/TriangularTests.cs",
  "cases": [
    {
      "name": "triangular_0_5_10_inverse_cdf_0",
      "construct": { "type": "Triangular", "params": [0, 5, 10, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.0], "expected": 0.0, "tol": 1e-5, "mode": "abs" }
      ]
    },
    {
      "name": "triangular_0_5_10_inverse_cdf_075",
      "construct": { "type": "Triangular", "params": [0, 5, 10, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.75], "expected": 6.464466, "tol": 1e-5, "mode": "abs" }
      ]
    },
    {
      "name": "triangular_0_5_10_inverse_cdf_025",
      "construct": { "type": "Triangular", "params": [0, 5, 10, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.25], "expected": 3.535534, "tol": 1e-5, "mode": "abs" }
      ]
    },
    {
      "name": "triangular_0_5_10_inverse_cdf_05",
      "construct": { "type": "Triangular", "params": [0, 5, 10, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.5], "expected": 5.0, "tol": 1e-5, "mode": "abs" }
      ]
    },
    {
      "name": "triangular_0_5_10_inverse_cdf_1",
      "construct": { "type": "Triangular", "params": [0, 5, 10, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [1.0], "expected": 10.0, "tol": 1e-5, "mode": "abs" }
      ]
    },
    {
      "name": "triangular_bad_min_gt_mostlikely_and_max",
      "construct": { "type": "Triangular", "params": [0, -1, -2, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" }
      ]
    },
    {
      "name": "triangular_bad_mostlikely_lt_min",
      "construct": { "type": "Triangular", "params": [-1, -2, 3, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" }
      ]
    },
    {
      "name": "triangular_bad_mostlikely_gt_max",
      "construct": { "type": "Triangular", "params": [-1, 4, 3, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" }
      ]
    },
    {
      "name": "triangular_bad_sample_size",
      "construct": { "type": "Triangular", "params": [-1, 1, 2, -1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "triangular_minor_all_equal",
      "construct": { "type": "Triangular", "params": [0, 0, 0, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 2, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "triangular_minor_min_eq_mostlikely",
      "construct": { "type": "Triangular", "params": [0, 0, 3, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 2, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "triangular_minor_mostlikely_eq_max",
      "construct": { "type": "Triangular", "params": [-1, 3, 3, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 2, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "triangular_good_0_1_2",
      "construct": { "type": "Triangular", "params": [0, 1, 2, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 0, "tol": 0.0, "mode": "bool" }
      ]
    },
    {
      "name": "triangular_good_neg1_2_3",
      "construct": { "type": "Triangular", "params": [-1, 2, 3, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 0, "tol": 0.0, "mode": "bool" }
      ]
    }
  ]
}
