{
  "target": "distribution",
  "kind": "distribution",
  "source_test": "HEC.FDA.StatisticsTests/Distributions/LogNormalTests.cs",
  "cases": [
    {
      "name": "lognormal_bad_validation_1",
      "construct": { "type": "LogNormal", "params": [0, -1, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "lognormal_bad_validation_2",
      "construct": { "type": "LogNormal", "params": [0, 1, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "lognormal_bad_validation_3",
      "construct": { "type": "LogNormal", "params": [-1, -2, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "lognormal_bad_validation_4",
      "construct": { "type": "LogNormal", "params": [-1, 1, -1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "lognormal_bad_validation_5",
      "construct": { "type": "LogNormal", "params": [1, 1, -1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "lognormal_inverse_cdf_1",
      "construct": { "type": "LogNormal", "params": [-1.5, 0.25, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.974], "expected": 0.3633, "tol": 0.05, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_inverse_cdf_2",
      "construct": { "type": "LogNormal", "params": [-0.5, 0.75, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.152], "expected": 0.2802, "tol": 0.05, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_inverse_cdf_3",
      "construct": { "type": "LogNormal", "params": [0.5, 1.25, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.008], "expected": 0.0812, "tol": 0.05, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_inverse_cdf_4",
      "construct": { "type": "LogNormal", "params": [1.5, 1.75, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.607], "expected": 7.208, "tol": 0.05, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_inverse_cdf_5",
      "construct": { "type": "LogNormal", "params": [2.5, 2.25, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.278], "expected": 3.231, "tol": 0.05, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_inverse_cdf_6",
      "construct": { "type": "LogNormal", "params": [3.5, 2.75, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.269], "expected": 6.098, "tol": 0.05, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_inverse_cdf_7",
      "construct": { "type": "LogNormal", "params": [5.2983, 2.9957, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.8], "expected": 2487.5, "tol": 0.05, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_cdf_pdf_1",
      "construct": { "type": "LogNormal", "params": [-0.5, 0.75, 1] },
      "assertions": [
        { "method": "pdf", "args": [0.895], "expected": 0.349, "tol": 0.005, "mode": "abs" },
        { "method": "cdf", "args": [0.895], "expected": 0.698, "tol": 0.005, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_cdf_pdf_2",
      "construct": { "type": "LogNormal", "params": [0.5, 1.25, 1] },
      "assertions": [
        { "method": "pdf", "args": [1.527], "expected": 0.398, "tol": 0.005, "mode": "abs" },
        { "method": "cdf", "args": [1.527], "expected": 0.476, "tol": 0.005, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_cdf_pdf_3",
      "construct": { "type": "LogNormal", "params": [1.5, 1.75, 1] },
      "assertions": [
        { "method": "pdf", "args": [1.601], "expected": 0.336, "tol": 0.005, "mode": "abs" },
        { "method": "cdf", "args": [1.601], "expected": 0.278, "tol": 0.005, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_cdf_pdf_4",
      "construct": { "type": "LogNormal", "params": [2.5, 2.25, 1] },
      "assertions": [
        { "method": "pdf", "args": [1.799], "expected": 0.278, "tol": 0.005, "mode": "abs" },
        { "method": "cdf", "args": [1.799], "expected": 0.198, "tol": 0.005, "mode": "abs" }
      ]
    },
    {
      "name": "lognormal_cdf_pdf_5",
      "construct": { "type": "LogNormal", "params": [3.5, 2.75, 1] },
      "assertions": [
        { "method": "pdf", "args": [2.721], "expected": 0.264, "tol": 0.005, "mode": "abs" },
        { "method": "cdf", "args": [2.721], "expected": 0.182, "tol": 0.005, "mode": "abs" }
      ]
    }
  ]
}
