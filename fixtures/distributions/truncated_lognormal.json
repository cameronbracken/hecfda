{
  "target": "distribution",
  "kind": "distribution",
  "source_test": "planning-captured: no dedicated TruncatedLogNormalTests.cs upstream -- oracles computed then pinned via tools/verify_oracles.py against the real C# TruncatedLogNormal (see fixtures/README.md)",
  "cases": [
    {
      "name": "quirk_pdf_ignores_mean_sd_a",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 20.0, 1] },
      "assertions": [
        { "method": "pdf", "args": [3.0], "expected": 0.21818476841998413, "tol": 1e-12, "mode": "rel" },
        { "method": "cdf", "args": [3.0], "expected": 0.8640313923585754, "tol": 1e-12, "mode": "rel" }
      ]
    },
    {
      "name": "quirk_pdf_ignores_mean_sd_b_different_mean_sd_same_result",
      "construct": { "type": "TruncatedLogNormal", "params": [5.0, 2.0, 1.0, 20.0, 1] },
      "assertions": [
        { "method": "pdf", "args": [3.0], "expected": 0.21818476841998413, "tol": 1e-12, "mode": "rel" },
        { "method": "cdf", "args": [3.0], "expected": 0.8640313923585754, "tol": 1e-12, "mode": "rel" }
      ]
    },
    {
      "name": "pdf_cdf_within_truncation",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 10.0, 1] },
      "assertions": [
        { "method": "pdf", "args": [5.0], "expected": 0.10925357415163602, "tol": 1e-12, "mode": "rel" },
        { "method": "cdf", "args": [5.0], "expected": 0.9462396895483367, "tol": 1e-12, "mode": "rel" }
      ]
    },
    {
      "name": "pdf_cdf_at_min_bound",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 10.0, 1] },
      "assertions": [
        { "method": "pdf", "args": [1.0], "expected": 0.3989422804014327, "tol": 1e-12, "mode": "rel" },
        { "method": "cdf", "args": [1.0], "expected": 0.5, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "pdf_cdf_outside_truncation_no_renormalization",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 10.0, 1] },
      "assertions": [
        { "method": "pdf", "args": [50.0], "expected": 0.00018954188464691336, "tol": 1e-12, "mode": "rel" },
        { "method": "cdf", "args": [50.0], "expected": 0.99995423690475005, "tol": 1e-12, "mode": "rel" }
      ]
    },
    {
      "name": "inverse_cdf_p0_clamps_to_min",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.0], "expected": 1.0, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "inverse_cdf_p1_clamps_to_max",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [1.0], "expected": 5.0, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "inverse_cdf_p025",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.25], "expected": 1.9404219122642286, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "inverse_cdf_p05",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.5], "expected": 2.7182818284590451, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "inverse_cdf_p075",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.75], "expected": 3.8079636455499259, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "inverse_cdf_interior_p_unclamped_quirk",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 0.5, 1.0, 3.0, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.75], "expected": 3.8079636455499259, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "truncated_lognormal_bad_sd",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, -1.0, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "truncated_lognormal_bad_mean",
      "construct": { "type": "TruncatedLogNormal", "params": [-1.0, 1.0, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "truncated_lognormal_bad_sample_size",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 1.0, 1.0, 5.0, 0] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "truncated_lognormal_bad_mean_and_sd",
      "construct": { "type": "TruncatedLogNormal", "params": [-1.0, -1.0, 1.0, 5.0, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 1, "tol": 0.0, "mode": "bool" },
        { "method": "error_level", "args": [], "expected": 32, "tol": 0.0, "mode": "exact" }
      ]
    },
    {
      "name": "truncated_lognormal_good",
      "construct": { "type": "TruncatedLogNormal", "params": [1.0, 1.0, 1.0, 10.0, 1] },
      "assertions": [
        { "method": "has_errors", "args": [], "expected": 0, "tol": 0.0, "mode": "bool" }
      ]
    }
  ]
}
