{
  "target": "distribution",
  "kind": "distribution",
  "source_test": "HEC.FDA.Statistics/Distributions/Normal.cs",
  "cases": [
    {
      "name": "standard_normal",
      "construct": { "type": "Normal", "params": [0.0, 1.0, 1] },
      "assertions": [
        { "method": "inverse_cdf", "args": [0.5], "expected": 0.0, "tol": 0.0, "mode": "abs" },
        { "method": "pdf", "args": [0.0], "expected": 0.3989422804014327, "tol": 1e-12, "mode": "rel" },
        { "method": "cdf", "args": [0.0], "expected": 0.5, "tol": 1e-9, "mode": "abs" }
      ]
    },
    {
      "name": "normal_fit",
      "construct": { "type": "Normal", "params": [0.0, 1.0, 1] },
      "assertions": [
        { "method": "fit_mean", "args": [2, 4, 4, 4, 5, 5, 7, 9], "expected": 5.0, "tol": 1e-9, "mode": "rel" },
        { "method": "fit_standard_deviation", "args": [2, 4, 4, 4, 5, 5, 7, 9], "expected": 2.0, "tol": 1e-9, "mode": "rel" },
        { "method": "fit_sample_size", "args": [2, 4, 4, 4, 5, 5, 7, 9], "expected": 8, "tol": 0.0, "mode": "exact" }
      ]
    }
  ]
}
