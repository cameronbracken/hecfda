        { "method": "incomplete_beta", "args": [2.0, 3.0, 0.5], "expected": 0.05729166666666689, "tol": 1e-11, "mode": "rel" },
        { "method": "reg_incomplete_beta", "args": [2.0, 3.0, 0.5], "expected": 0.6875000000000009, "tol": 1e-11, "mode": "rel" }
